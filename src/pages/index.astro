---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<MainLayout>
  <Navbar />

  <main class="flex-1">
    <section class="max-w-7xl mx-auto px-6 py-32 text-center">

      <p class="uppercase tracking-[0.3em] text-blue-400 text-sm mb-6">
        Offensive Security
      </p>

      <h1 class="text-6xl md:text-8xl font-bold leading-tight">
        Sardar Anonymous
      </h1>

      <h2 class="text-2xl md:text-3xl mt-6 text-zinc-300">
        Web Application Penetration Tester
      </h2>

      <p class="max-w-3xl mx-auto mt-8 text-zinc-400 text-lg leading-8">
        Helping organizations identify and responsibly disclose security
        vulnerabilities before attackers can exploit them.
      </p>

      <div class="flex flex-wrap justify-center gap-5 mt-12">

        <a
          href="#projects"
          class="bg-blue-600 hover:bg-blue-500 px-7 py-4 rounded-xl transition"
        >
          View Projects
        </a>

        <a
          href="/resume.pdf"
          class="border border-zinc-700 hover:border-blue-500 px-7 py-4 rounded-xl transition"
        >
          Download Resume
        </a>

      </div>

    </section>
  </main>

  <Footer />
</MainLayout>