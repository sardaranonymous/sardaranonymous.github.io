---
import ProjectTag from "./ProjectTag.astro";

interface Props {
  project: any;
}

const { project } = Astro.props;
---

<div
  class="overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900 hover:border-blue-500 transition-all duration-300 hover:-translate-y-2"
>

  <img
    src={project.image}
    alt={project.title}
    class="h-56 w-full object-cover"
  />

  <div class="p-8">

    <div class="flex items-center justify-between">

      <h3
        class="text-2xl font-bold font-['Space_Grotesk']"
      >
        {project.title}
      </h3>

      <span
        class="text-green-400 text-sm"
      >
        {project.status}
      </span>

    </div>

    <p
      class="mt-6 text-zinc-400 leading-8"
    >
      {project.description}
    </p>

    <div
      class="flex flex-wrap gap-2 mt-8"
    >

      {
        project.technologies.map((tech: string) => (

          <ProjectTag text={tech} />

        ))
      }

    </div>

    <div
      class="flex gap-4 mt-8"
    >

      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg bg-blue-600 px-5 py-3 hover:bg-blue-500 transition"
      >
        GitHub
      </a>

    </div>

  </div>

</div>