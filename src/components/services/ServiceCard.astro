---
const { service } = Astro.props;
---

<div class="rounded-xl border border-zinc-800 bg-zinc-900 p-6 hover:border-blue-500 transition duration-300">

  <div class="text-4xl">
    {service.icon}
  </div>

  <h3 class="mt-5 text-xl font-semibold">
    {service.title}
  </h3>

  <p class="mt-4 text-zinc-400 leading-relaxed">
    {service.description}
  </p>

</div>