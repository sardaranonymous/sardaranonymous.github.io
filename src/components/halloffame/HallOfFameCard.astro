---
interface Props {
  company: string;
  date: string;
  image: string;
  description: string;
  link: string;
}

const { company, date, image, description, link } = Astro.props;
---

<article
  class="group relative rounded-2xl transition-all duration-300"
>

  <!-- Blue Glow -->

  <div
    class="absolute -inset-1 rounded-2xl bg-blue-500/25 opacity-0 blur-xl transition-all duration-500 group-hover:opacity-100"
  ></div>

  <!-- Card -->

  <div
    class="relative overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900 transition-all duration-300 group-hover:-translate-y-3 group-hover:border-blue-500 group-hover:shadow-[0_0_35px_rgba(59,130,246,0.20)]"
  >

    <!-- Image -->

    <div class="overflow-hidden bg-zinc-950">

      <img
        src={image}
        alt={company}
        class="h-52 w-full object-cover transition-transform duration-700 group-hover:scale-110"
      />

    </div>

    <!-- Content -->

    <div class="p-6">

      <div class="mb-4 flex items-center justify-between">

        <h3
          class="text-2xl font-bold transition-colors duration-300 group-hover:text-blue-400"
        >
          {company}
        </h3>

        <span
          class="rounded-full bg-blue-600 px-3 py-1 text-xs font-medium transition-all duration-300 group-hover:bg-blue-500"
        >
          {date}
        </span>

      </div>

      <p
        class="leading-7 text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300"
      >
        {description}
      </p>

      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-blue-600 px-5 py-3 font-medium transition-all duration-300 hover:scale-105 hover:bg-blue-500 hover:shadow-lg"
      >

        View Recognition

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 7l-10 10M8 7h9v9"
          />
        </svg>

      </a>

    </div>

  </div>

</article>