---
import { hallOfFame } from "../../data/halloffame";
import HallOfFameCard from "./HallOfFameCard.astro";
---

<section
  id="hall-of-fame"
  class="py-28 border-t border-zinc-800 bg-zinc-950"
>

  <div class="max-w-7xl mx-auto px-6">

    <!-- Heading -->

    <div
      class="max-w-3xl"
      data-aos="fade-up"
    >

      <p class="uppercase tracking-[0.35em] text-blue-400 text-sm font-semibold">
        Recognition
      </p>

      <h2
        class="mt-4 text-4xl md:text-5xl font-bold font-['Space_Grotesk']"
      >
        {hallOfFame.title}
      </h2>

      <p
        class="mt-8 text-zinc-400 text-lg leading-9"
      >
        {hallOfFame.description}
      </p>

    </div>

    <!-- Cards -->

    <div
      class="grid gap-8 mt-16 md:grid-cols-2 xl:grid-cols-3"
    >

      {
        hallOfFame.recognitions.map((item, index) => (

          <div
            data-aos="zoom-in-up"
            data-aos-delay={index * 120}
          >

            <HallOfFameCard
              company={item.company}
              date={item.date}
              image={item.image}
              description={item.description}
              link={item.link}
            />

          </div>

        ))
      }

    </div>

  </div>

</section>