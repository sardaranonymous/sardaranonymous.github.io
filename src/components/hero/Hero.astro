---
import { hero } from "../../data/hero";
import { stats } from "../../data/stats";
import { site } from "../../data/site";
---

<section
  id="home"
  class="relative overflow-hidden min-h-screen flex items-center justify-center bg-zinc-950"
>
  <!-- Background -->
  <div class="absolute inset-0 -z-20">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-950/20 via-zinc-950 to-zinc-950"></div>

    <div
      class="absolute left-1/2 top-0 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-blue-600/20 blur-3xl"
    ></div>
  </div>

  <div
    class="max-w-7xl mx-auto px-6 py-24 grid lg:grid-cols-2 gap-20 items-center"
  >
    <!-- Left -->
    <div>

      <span
        class="inline-flex items-center rounded-full border border-blue-500/40 bg-blue-500/10 px-4 py-2 text-sm text-blue-300"
      >
        {hero.badge}
      </span>

      <h1
        class="mt-8 text-5xl md:text-7xl font-black leading-tight tracking-tight"
      >
        {hero.title}
      </h1>

      <h2
        class="mt-5 text-2xl md:text-3xl text-blue-400 font-semibold"
      >
        {hero.subtitle}
      </h2>

      <p
        class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400"
      >
        {hero.description}
      </p>

      <div class="mt-10 flex flex-wrap gap-5">

        <a
          href={hero.primaryButton.href}
          class="rounded-xl bg-blue-600 px-8 py-4 font-medium transition hover:bg-blue-500"
        >
          {hero.primaryButton.text}
        </a>

        <a
          href={hero.secondaryButton.href}
          class="rounded-xl border border-zinc-700 px-8 py-4 font-medium transition hover:border-blue-500"
        >
          {hero.secondaryButton.text}
        </a>

      </div>

      <!-- Stats -->

      <div
        class="mt-14 grid grid-cols-2 gap-5 md:grid-cols-4"
      >

        {
          stats.map((item) => (
            <div
              class="rounded-xl border border-zinc-800 bg-zinc-900/60 p-5 backdrop-blur"
            >
              <h3 class="text-2xl font-bold text-white">
                {item.number}
              </h3>

              <p class="mt-2 text-sm text-zinc-400">
                {item.title}
              </p>
            </div>
          ))
        }

      </div>

    </div>

    <!-- Right -->

    <div class="flex justify-center">

      <div class="relative">

        <div
          class="absolute -inset-5 rounded-full bg-blue-600/20 blur-3xl"
        ></div>

        <img
          src={site.profileImage}
          alt={site.name}
          class="relative h-80 w-80 rounded-full border-4 border-zinc-800 object-cover shadow-2xl lg:h-[430px] lg:w-[430px]"
        />

      </div>

    </div>

  </div>

</section>