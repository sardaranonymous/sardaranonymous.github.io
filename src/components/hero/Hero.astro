---
import { hero } from "../../data/hero";
import { stats } from "../../data/stats";
import { site } from "../../data/site";
---

<section
  id="home"
  class="relative flex min-h-screen items-center justify-center overflow-hidden bg-zinc-950"
  data-aos="fade-up"
>

  <!-- Background -->

  <div class="absolute inset-0 -z-20">

    <div class="absolute inset-0 bg-gradient-to-b from-blue-950/20 via-zinc-950 to-zinc-950"></div>

    <div
      class="absolute left-1/2 top-0 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-blue-600/20 blur-3xl animate-pulse"
    ></div>

  </div>

  <div
    class="mx-auto grid max-w-7xl items-center gap-20 px-6 py-24 lg:grid-cols-2"
  >

    <!-- Left -->

    <div
      data-aos="fade-right"
      data-aos-delay="150"
    >

      <span
        class="inline-flex items-center rounded-full border border-blue-500/40 bg-blue-500/10 px-4 py-2 text-sm text-blue-300"
      >
        {hero.badge}
      </span>

      <h1
        class="mt-8 text-5xl font-black leading-tight tracking-tight md:text-7xl"
      >
        {hero.title}
      </h1>

      <h2
        class="mt-5 text-2xl font-semibold text-blue-400 md:text-3xl"
      >
        {hero.subtitle}
      </h2>

      <p
        class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400"
      >
        {hero.description}
      </p>

      <!-- Buttons -->

      <div
        class="mt-10 flex flex-wrap gap-5"
        data-aos="zoom-in"
        data-aos-delay="400"
      >

        <a
          href={hero.primaryButton.href}
          class="group relative overflow-hidden rounded-xl bg-blue-600 px-8 py-4 font-medium transition-all duration-300 hover:-translate-y-1 hover:scale-105 hover:bg-blue-500 hover:shadow-[0_0_30px_rgba(59,130,246,0.45)]"
        >

          <span class="relative z-10">
            {hero.primaryButton.text}
          </span>

          <div
            class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 bg-gradient-to-r from-blue-400/20 via-white/10 to-blue-400/20"
          ></div>

        </a>

        <a
          href={hero.secondaryButton.href}
          class="rounded-xl border border-zinc-700 px-8 py-4 font-medium transition-all duration-300 hover:-translate-y-1 hover:scale-105 hover:border-blue-500 hover:bg-zinc-900 hover:shadow-[0_0_25px_rgba(59,130,246,0.20)]"
        >
          {hero.secondaryButton.text}
        </a>

      </div>

      <!-- Stats -->

      <div
        class="mt-14 grid grid-cols-2 gap-5 md:grid-cols-4"
      >

        {
          stats.map((item, index) => (

            <div
              data-aos="zoom-in-up"
              data-aos-delay={650 + index * 120}
              class="group relative rounded-xl transition-all duration-500"
            >

              <!-- Glow -->

              <div
                class="absolute -inset-1 rounded-xl bg-blue-500/20 opacity-0 blur-xl transition-all duration-700 group-hover:scale-105 group-hover:opacity-100"
              ></div>

              <!-- Card -->

              <div
                class="relative rounded-xl border border-zinc-800 bg-zinc-900/60 p-5 backdrop-blur transition-all duration-500 group-hover:-translate-y-3 group-hover:scale-[1.03] group-hover:border-blue-500 group-hover:shadow-[0_0_35px_rgba(59,130,246,0.20)]"
              >

                <h3
                  class="text-2xl font-bold text-white transition-colors duration-300 group-hover:text-blue-400"
                >
                  {item.number}
                </h3>

                <p
                  class="mt-2 text-sm text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300"
                >
                  {item.title}
                </p>

              </div>

            </div>

          ))
        }

      </div>

    </div>

    <!-- Right -->

    <div
      class="flex justify-center"
      data-aos="fade-left"
      data-aos-delay="250"
    >

      <div class="group relative">

        <div
          class="absolute -inset-6 rounded-full bg-blue-600/25 blur-3xl transition-all duration-700 group-hover:scale-110 group-hover:bg-blue-500/35"
        ></div>

        <img
          src={site.profileImage}
          alt={site.name}
          class="relative h-80 w-80 rounded-full border-4 border-zinc-800 object-cover shadow-2xl transition-all duration-700 group-hover:scale-105 group-hover:shadow-[0_0_60px_rgba(59,130,246,0.35)] lg:h-[430px] lg:w-[430px]"
        />

      </div>

    </div>

  </div>

</section>