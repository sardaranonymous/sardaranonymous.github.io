---
interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<div
  class="rounded-2xl border border-zinc-800 bg-zinc-900/60 p-6 text-center hover:border-blue-500 transition-all duration-300"
>
  <h3 class="text-4xl font-bold text-blue-400">
    {number}
  </h3>

  <p class="mt-3 text-zinc-400">
    {label}
  </p>
</div>