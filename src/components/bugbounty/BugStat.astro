---
interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<div
  class="group relative rounded-2xl transition-all duration-300"
>

  <!-- Blue Glow -->

  <div
    class="absolute -inset-1 rounded-2xl bg-blue-500/25 opacity-0 blur-xl transition-all duration-500 group-hover:opacity-100"
  ></div>

  <!-- Card -->

  <div
    class="relative rounded-2xl border border-zinc-800 bg-zinc-900/60 p-6 text-center transition-all duration-300 group-hover:-translate-y-3 group-hover:border-blue-500 group-hover:shadow-[0_0_35px_rgba(59,130,246,0.20)]"
  >

    <h3
      class="text-4xl font-bold text-blue-400 transition-all duration-300 group-hover:scale-110"
    >
      {number}
    </h3>

    <p
      class="mt-3 text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300"
    >
      {label}
    </p>

  </div>

</div>