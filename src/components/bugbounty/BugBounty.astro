---
import { bugBounty } from "../../data/bugbounty";
import BugStat from "./BugStat.astro";
---

<section
  id="bug-bounty"
  class="py-28 border-t border-zinc-800 bg-zinc-950"
>

  <div class="max-w-7xl mx-auto px-6">

    <!-- Heading -->

    <div
      class="max-w-3xl"
      data-aos="fade-up"
    >

      <p
        class="uppercase tracking-[0.35em] text-blue-400 text-sm font-semibold"
      >
        Security Research
      </p>

      <h2
        class="mt-4 text-4xl md:text-5xl font-bold font-['Space_Grotesk']"
      >
        {bugBounty.title}
      </h2>

      <p
        class="mt-8 text-zinc-400 text-lg leading-9"
      >
        {bugBounty.description}
      </p>

    </div>

    <!-- Statistics -->

    <div class="mt-16 grid gap-6 md:grid-cols-2 xl:grid-cols-4">

      {
        bugBounty.stats.map((stat, index) => (

          <div
            data-aos="zoom-in-up"
            data-aos-delay={index * 120}
          >

            <BugStat
              number={stat.number}
              label={stat.label}
            />

          </div>

        ))
      }

    </div>

    <!-- Platforms -->

    <div
      class="mt-20"
      data-aos="fade-up"
      data-aos-delay="150"
    >

      <h3
        class="mb-8 font-['Space_Grotesk'] text-2xl font-bold"
      >
        Platforms
      </h3>

      <div class="flex flex-wrap gap-4">

        {
          bugBounty.platforms.map((platform, index) => (

            <span
              data-aos="zoom-in"
              data-aos-delay={index * 100}
              class="cursor-default rounded-full border border-blue-500/30 bg-blue-600/10 px-5 py-2 text-blue-300 transition-all duration-300 hover:-translate-y-1 hover:border-blue-400 hover:bg-blue-500/20 hover:shadow-lg hover:shadow-blue-500/20"
            >
              {platform}
            </span>

          ))
        }

      </div>

    </div>

    <!-- Methodology -->

    <div
      class="mt-20"
      data-aos="fade-up"
    >

      <h3
        class="mb-8 font-['Space_Grotesk'] text-2xl font-bold"
      >
        Research Methodology
      </h3>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">

        {
          bugBounty.methodology.map((step, index) => (

            <div
              data-aos="fade-up"
              data-aos-delay={index * 120}
              class="group relative rounded-xl"
            >

              <!-- Blue Glow -->

              <div
                class="absolute -inset-1 rounded-xl bg-blue-500/25 opacity-0 blur-xl transition-all duration-500 group-hover:opacity-100"
              ></div>

              <!-- Card -->

              <div
                class="relative rounded-xl border border-zinc-800 bg-zinc-900/60 p-5 transition-all duration-300 group-hover:-translate-y-3 group-hover:border-blue-500 group-hover:shadow-[0_0_35px_rgba(59,130,246,0.20)]"
              >

                <p
                  class="text-zinc-300 transition-colors duration-300 group-hover:text-white"
                >
                  {step}
                </p>

              </div>

            </div>

          ))
        }

      </div>

    </div>

  </div>

</section>