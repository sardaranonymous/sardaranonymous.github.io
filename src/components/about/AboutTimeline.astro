---
import { timeline } from "../../data/timeline";
---

<div
  class="relative ml-3"
  data-aos="fade-up"
>

  <!-- Animated Timeline Line -->

  <div
    class="absolute left-0 top-0 h-full w-[2px] origin-top bg-gradient-to-b from-blue-500 via-blue-400 to-blue-700"
    data-aos="zoom-y-out"
    data-aos-duration="1200"
  ></div>

  {
    timeline.map((item, index) => (

      <div
        class="group relative pb-14 pl-10"
        data-aos="fade-right"
        data-aos-delay={index * 150}
      >

        <!-- Timeline Dot -->

        <span
          class="absolute -left-[11px] top-1 flex h-6 w-6 items-center justify-center rounded-full border-4 border-zinc-950 bg-blue-500 transition-all duration-300 group-hover:scale-125 group-hover:shadow-[0_0_25px_rgba(59,130,246,0.9)]"
        ></span>

        <!-- Year -->

        <p
          class="text-xs font-bold uppercase tracking-[0.35em] text-blue-400 transition-colors duration-300 group-hover:text-blue-300"
        >
          {item.year}
        </p>

        <!-- Title -->

        <h4
          class="mt-3 text-2xl font-bold font-['Space_Grotesk'] text-white transition-colors duration-300 group-hover:text-blue-400"
        >
          {item.title}
        </h4>

        <!-- Description -->

        <p
          class="mt-4 max-w-3xl leading-7 text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300"
        >
          {item.description}
        </p>

      </div>

    ))
  }

</div>