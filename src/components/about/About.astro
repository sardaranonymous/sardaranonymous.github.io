---
import { about } from "../../data/about";
import { specializations } from "../../data/specializations";
import { timeline } from "../../data/timeline";

import AboutHighlights from "./AboutHighlights.astro";
import AboutTimeline from "./AboutTimeline.astro";
import SpecializationCard from "./SpecializationCard.astro";
---

<section
  id="about"
  class="relative py-28 border-t border-zinc-800 bg-zinc-950"
>
  <div class="max-w-7xl mx-auto px-6">

    <!-- Heading -->

    <div class="max-w-3xl">

      <p
        class="uppercase tracking-[0.35em] text-blue-400 text-sm font-semibold"
      >
        About Me
      </p>

      <h2
        class="mt-4 text-4xl md:text-5xl font-bold font-['Space_Grotesk']"
      >
        {about.title}
      </h2>

      <p
        class="mt-8 text-zinc-400 text-lg leading-9 whitespace-pre-line"
      >
        {about.description}
      </p>

    </div>

    <!-- Highlights -->

    <div class="mt-16">

      <AboutHighlights />

    </div>

    <!-- Specializations -->

    <div class="mt-24">

      <h3
        class="text-3xl font-bold font-['Space_Grotesk'] mb-10"
      >
        Specializations
      </h3>

      <div
        class="grid gap-6 md:grid-cols-2 xl:grid-cols-4"
      >

        {
          specializations.map((item) => (

            <SpecializationCard
              title={item.title}
              description={item.description}
            />

          ))
        }

      </div>

    </div>

    <!-- Timeline -->

    <div class="mt-24">

      <h3
        class="text-3xl font-bold font-['Space_Grotesk'] mb-10"
      >
        Professional Journey
      </h3>

      <AboutTimeline />

    </div>

  </div>
</section>