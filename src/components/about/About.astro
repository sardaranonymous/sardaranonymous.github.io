---
import { about } from "../../data/about";
import { specializations } from "../../data/specializations";
import { timeline } from "../../data/timeline";

import AboutHighlights from "./AboutHighlights.astro";
import AboutTimeline from "./AboutTimeline.astro";
import SpecializationCard from "./SpecializationCard.astro";
---

<section
  id="about"
  class="relative border-t border-zinc-800 bg-zinc-950 py-28"
>

  <div class="mx-auto max-w-7xl px-6">

    <!-- Heading -->

    <div
      class="max-w-3xl"
      data-aos="fade-up"
    >

      <p
        class="text-sm font-semibold uppercase tracking-[0.35em] text-blue-400"
      >
        About Me
      </p>

      <h2
        class="mt-4 font-['Space_Grotesk'] text-4xl font-bold md:text-5xl"
      >
        {about.title}
      </h2>

      <p
        class="mt-8 whitespace-pre-line text-lg leading-9 text-zinc-400"
      >
        {about.description}
      </p>

    </div>

    <!-- Highlights -->

    <div
      class="mt-16"
      data-aos="fade-up"
      data-aos-delay="100"
    >

      <AboutHighlights />

    </div>

    <!-- Specializations -->

    <div
      class="mt-24"
      data-aos="fade-up"
      data-aos-delay="150"
    >

      <h3
        class="mb-10 font-['Space_Grotesk'] text-3xl font-bold"
      >
        Specializations
      </h3>

      <div
        class="grid gap-6 md:grid-cols-2 xl:grid-cols-4"
      >

        {
          specializations.map((item, index) => (

            <div
              data-aos="zoom-in-up"
              data-aos-delay={index * 120}
            >

              <SpecializationCard
                title={item.title}
                description={item.description}
              />

            </div>

          ))
        }

      </div>

    </div>

    <!-- Timeline -->

    <div
      class="mt-24"
      data-aos="fade-up"
      data-aos-delay="200"
    >

      <h3
        class="mb-10 font-['Space_Grotesk'] text-3xl font-bold"
      >
        Professional Journey
      </h3>

      <AboutTimeline />

    </div>

  </div>

</section>