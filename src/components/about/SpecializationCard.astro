---
interface Props {

  title: string;

  description: string;

}

const { title, description } = Astro.props;
---

<div
  class="rounded-2xl border border-zinc-800 bg-zinc-900/60 backdrop-blur-md p-8 hover:border-blue-500 hover:-translate-y-2 transition-all duration-300"
>

  <div
    class="w-14 h-14 rounded-xl bg-blue-600/20 flex items-center justify-center text-2xl mb-6"
  >
    🛡️
  </div>

  <h4
    class="text-xl font-semibold mb-4 font-['Space_Grotesk']"
  >
    {title}
  </h4>

  <p
    class="text-zinc-400 leading-7"
  >
    {description}
  </p>

</div>