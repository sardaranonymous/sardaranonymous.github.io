---
import { about } from "../../data/about";
---

<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-5">

  {
    about.highlights.map((item, index) => (

      <div
        data-aos="zoom-in-up"
        data-aos-delay={index * 100}
        class="group relative rounded-2xl transition-all duration-300"
      >

        <!-- Blue Glow -->

        <div
          class="absolute -inset-1 rounded-2xl bg-blue-500/20 opacity-0 blur-xl transition-all duration-500 group-hover:opacity-100"
        ></div>

        <!-- Card -->

        <div
          class="relative rounded-2xl border border-zinc-800 bg-zinc-900/60 p-6 backdrop-blur-md transition-all duration-300 group-hover:-translate-y-2 group-hover:border-blue-500 group-hover:shadow-[0_0_30px_rgba(59,130,246,0.18)]"
        >

          <div class="flex items-center gap-3">

            <!-- Icon -->

            <div
              class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-600/20 text-lg text-blue-400 transition-all duration-300 group-hover:scale-110 group-hover:bg-blue-600/30"
            >
              ✓
            </div>

            <!-- Text -->

            <p
              class="font-medium text-zinc-200 transition-colors duration-300 group-hover:text-blue-400"
            >
              {item}
            </p>

          </div>

        </div>

      </div>

    ))
  }

</div>