```astro
---
const { item } = Astro.props;
---

<div class="rounded-xl border border-zinc-800 bg-zinc-900 overflow-hidden hover:border-blue-500 transition">

  <img
    src={item.image}
    alt={item.title}
    class="h-44 w-full object-contain bg-zinc-950 p-6"
  />

  <div class="p-6">

    <h3 class="text-xl font-semibold">
      {item.title}
    </h3>

    <p class="mt-2 text-zinc-400">
      {item.issuer}
    </p>

    <p class="mt-1 text-sm text-zinc-500">
      Issued: {item.year}
    </p>

    {
      item.verify && (
        <a
          href={item.verify}
          target="_blank"
          class="mt-5 inline-flex rounded-lg bg-blue-600 px-4 py-2 hover:bg-blue-500 transition"
        >
          Verify Certificate
        </a>
      )
    }

  </div>

</div>
```
