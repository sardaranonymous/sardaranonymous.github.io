---
const navItems = [
  { name: "About", href: "/#about" },
  { name: "Skills", href: "/#skills" },
  { name: "Services", href: "/#services" },
  { name: "Projects", href: "/projects" },
  { name: "Hall of Fame", href: "/#hall-of-fame" },
  { name: "Certifications", href: "/#certifications" },
  { name: "Bug Bounty", href: "/#bug-bounty" },
  { name: "Contact", href: "/#contact" },
];
---

<header class="sticky top-0 z-50 border-b border-zinc-800 bg-zinc-950/70 backdrop-blur-xl">

  <nav class="mx-auto max-w-7xl px-6">

    <div class="flex h-20 items-center justify-between">

      <!-- Logo -->

      <a
        href="/"
        class="group flex flex-col transition-all duration-300 hover:scale-[1.02]"
      >

        <span
          class="text-2xl font-bold tracking-tight transition-colors duration-300 group-hover:text-blue-400"
        >
          Sardar Anonymous
        </span>

        <span
          class="text-xs text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300"
        >
          Web Application Penetration Tester
        </span>

      </a>

      <!-- Desktop Navigation -->

      <div class="hidden items-center gap-8 md:flex">

        {
          navItems.map((item) => (

            <a
              href={item.href}
              class="group relative text-zinc-300 transition-all duration-300 hover:-translate-y-0.5 hover:text-blue-400"
            >

              {item.name}

              <span
                class="absolute -bottom-2 left-0 h-0.5 w-0 rounded-full bg-blue-500 transition-all duration-300 group-hover:w-full"
              ></span>

            </a>

          ))
        }

        <!-- Resume -->

        <a
          href="/resume.pdf"
          class="group relative overflow-hidden rounded-xl bg-blue-600 px-6 py-3 font-medium transition-all duration-300 hover:-translate-y-1 hover:scale-105 hover:bg-blue-500 hover:shadow-[0_0_30px_rgba(59,130,246,0.45)]"
        >

          <span class="relative z-10">
            Resume
          </span>

          <div
            class="absolute inset-0 bg-gradient-to-r from-blue-400/20 via-white/10 to-blue-400/20 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
          ></div>

        </a>

      </div>

      <!-- Mobile Menu Button -->

      <button
        id="menu-btn"
        aria-label="Open Menu"
        class="flex h-11 w-11 items-center justify-center rounded-xl border border-zinc-800 bg-zinc-900 transition-all duration-300 hover:border-blue-500 hover:text-blue-400 hover:shadow-[0_0_30px_rgba(59,130,246,0.35)] md:hidden"
      >

        <!-- Hamburger -->

        <svg
          id="menu-open"
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >

          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"
          />

        </svg>

        <!-- Close -->

        <svg
          id="menu-close"
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >

          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"
          />

        </svg>

      </button>

    </div>

    <!-- Mobile Navigation -->

    <div
      id="mobile-menu"
      class="max-h-0 overflow-hidden transition-all duration-500 md:hidden"
    >

      <div class="group relative mt-4">

        <!-- Blue Glow -->

        <div
          class="absolute -inset-1 rounded-2xl bg-blue-500/20 opacity-100 blur-xl"
        ></div>

        <!-- Menu Card -->

        <div
          class="relative rounded-2xl border border-zinc-800 bg-zinc-900/95 p-6 backdrop-blur-xl"
        >

          <div class="flex flex-col gap-4">

            {
              navItems.map((item) => (

                <a
                  href={item.href}
                  class="mobile-link rounded-lg px-4 py-3 text-zinc-300 transition-all duration-300 hover:bg-blue-500/10 hover:text-blue-400"
                >

                  {item.name}

                </a>

              ))
            }

            <a
              href="/resume.pdf"
              class="mt-2 rounded-xl bg-blue-600 px-6 py-3 text-center font-medium transition-all duration-300 hover:bg-blue-500 hover:shadow-[0_0_25px_rgba(59,130,246,0.45)]"
            >

              Resume

            </a>

          </div>

        </div>

      </div>

    </div>

  </nav>

</header>

<script is:inline>
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const openIcon = document.getElementById("menu-open");
  const closeIcon = document.getElementById("menu-close");

  function closeMenu() {
    if (!mobileMenu) return;

    mobileMenu.style.maxHeight = "0px";

    openIcon?.classList.remove("hidden");
    closeIcon?.classList.add("hidden");
  }

  function openMenu() {
    if (!mobileMenu) return;

    mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";

    openIcon?.classList.add("hidden");
    closeIcon?.classList.remove("hidden");
  }

  menuBtn?.addEventListener("click", () => {
    const opened =
      mobileMenu &&
      mobileMenu.style.maxHeight &&
      mobileMenu.style.maxHeight !== "0px";

    if (opened) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      closeMenu();
    });
  });

  // Close menu automatically when resizing to desktop
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) {
      closeMenu();
    }
  });
</script>