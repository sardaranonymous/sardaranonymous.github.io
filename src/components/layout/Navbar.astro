---
const navItems = [
  { name: "About", href: "/#about" },
  { name: "Skills", href: "/#skills" },
  { name: "Services", href: "/#services" },
  { name: "Projects", href: "/projects" },
  { name: "Hall of Fame", href: "/#hall-of-fame" },
  { name: "Certifications", href: "/#certifications" },
  { name: "Bug Bounty", href: "/#bug-bounty" },
  { name: "Contact", href: "/#contact" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-slate-950/75 backdrop-blur-xl"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4"
  >
    <!-- Logo -->
    <a
      href="/"
      class="text-xl font-bold tracking-wide text-white transition hover:text-blue-400"
    >
      <span class="text-blue-500">Sardar</span>Anonymous
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden items-center gap-2 lg:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="rounded-full px-4 py-2 text-sm font-medium text-slate-300 transition-all duration-300 hover:bg-blue-500/10 hover:text-blue-400 hover:shadow-[0_0_20px_rgba(59,130,246,0.45)]"
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile Button -->
    <button
      id="menuBtn"
      aria-label="Toggle Menu"
      aria-controls="mobileMenu"
      aria-expanded="false"
      class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/5 text-white transition hover:border-blue-500 hover:text-blue-400 lg:hidden"
    >
      <svg
        id="menuIcon"
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 transition duration-300"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobileMenu"
    class="max-h-0 overflow-hidden border-t border-white/10 bg-slate-950/95 transition-all duration-500 ease-in-out lg:hidden"
  >
    <ul class="flex flex-col px-6 py-4">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="mobile-link block rounded-lg px-4 py-3 text-slate-300 transition-all duration-300 hover:bg-blue-500/10 hover:text-blue-400 hover:shadow-[0_0_20px_rgba(59,130,246,0.4)]"
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const menuBtn = document.getElementById("menuBtn");
  const mobileMenu = document.getElementById("mobileMenu");
  const icon = document.getElementById("menuIcon");

  let open = false;

  function toggleMenu() {
    open = !open;

    menuBtn.setAttribute("aria-expanded", open);

    if (open) {
      mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";

      icon.innerHTML = `
        <path stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"/>
      `;
    } else {
      mobileMenu.style.maxHeight = "0px";

      icon.innerHTML = `
        <path stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"/>
      `;
    }
  }

  menuBtn?.addEventListener("click", toggleMenu);

  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");

      if (!href || !href.includes("#")) return;

      e.preventDefault();

      // Close menu first
      if (open) {
        toggleMenu();
      }

      const hash = href.split("#")[1];

      setTimeout(() => {
        const target = document.getElementById(hash);

        if (target) {
          target.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });

          history.replaceState(null, "", "#" + hash);
        } else {
          window.location.href = href;
        }
      }, 350);
    });
  });

  // Smooth scrolling for desktop links
  document.querySelectorAll('a[href^="/#"]').forEach((link) => {
    if (link.classList.contains("mobile-link")) return;

    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      const hash = href.split("#")[1];
      const target = document.getElementById(hash);

      if (!target) return;

      e.preventDefault();

      target.scrollIntoView({
        behavior: "smooth",
        block: "start",
      });

      history.replaceState(null, "", "#" + hash);
    });
  });
</script>

<style is:global>
html {
  scroll-behavior: smooth;
}

body {
  padding-top: 80px;
}
</style>