---
const navItems = [
  { name: "About", href: "#about" },
  { name: "Services", href: "#services" },
  { name: "Projects", href: "#projects" },
  { name: "Bug Bounty", href: "#bug-bounty" },
  { name: "Blog", href: "#blog" },
  { name: "Contact", href: "#contact" },
];
---

<header class="sticky top-0 z-50 border-b border-zinc-800 bg-zinc-950/70 backdrop-blur-xl">
  <nav class="max-w-7xl mx-auto px-6">
    <div class="flex h-20 items-center justify-between">

      <a href="/" class="flex flex-col">
        <span class="text-2xl font-bold tracking-tight">
          Sardar Anonymous
        </span>

        <span class="text-xs text-zinc-400">
          Web Application Penetration Tester
        </span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-zinc-300 transition-colors duration-300 hover:text-blue-400"
            >
              {item.name}
            </a>
          ))
        }

        <a
          href="/resume.pdf"
          class="rounded-lg bg-blue-600 px-5 py-2.5 transition hover:bg-blue-500"
        >
          Resume
        </a>
      </div>

    </div>
  </nav>
</header>