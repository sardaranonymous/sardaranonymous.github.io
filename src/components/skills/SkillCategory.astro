---
import SkillItem from "./SkillItem.astro";

interface Props {
  title: string;
  icon: string;
  skills: string[];
}

const { title, icon, skills } = Astro.props;
---

<div
  class="rounded-2xl border border-zinc-800 bg-zinc-900/60 backdrop-blur-md p-8 hover:border-blue-500 hover:-translate-y-2 transition-all duration-300"
>

  <div class="flex items-center gap-4 mb-6">

    <div
      class="w-14 h-14 rounded-xl bg-blue-600/20 flex items-center justify-center text-2xl"
    >
      {icon}
    </div>

    <h3
      class="text-2xl font-bold font-['Space_Grotesk']"
    >
      {title}
    </h3>

  </div>

  <div class="grid gap-3">

    {
      skills.map((skill) => (

        <SkillItem skill={skill} />

      ))
    }

  </div>

</div>