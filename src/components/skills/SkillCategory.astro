---
import SkillItem from "./SkillItem.astro";

interface Props {
  title: string;
  icon: string;
  skills: string[];
}

const { title, icon, skills } = Astro.props;
---

<div
  class="group relative rounded-2xl transition-all duration-300"
>

  <!-- Blue Glow -->

  <div
    class="absolute -inset-1 rounded-2xl bg-blue-500/20 opacity-0 blur-xl transition-all duration-500 group-hover:opacity-100"
  ></div>

  <!-- Card -->

  <div
    class="relative rounded-2xl border border-zinc-800 bg-zinc-900/60 p-8 backdrop-blur-md transition-all duration-300 group-hover:-translate-y-2 group-hover:border-blue-500 group-hover:shadow-[0_0_30px_rgba(59,130,246,0.20)]"
  >

    <!-- Header -->

    <div class="mb-6 flex items-center gap-4">

      <!-- Icon -->

      <div
        class="flex h-14 w-14 items-center justify-center rounded-xl bg-blue-600/20 text-2xl transition-all duration-300 group-hover:scale-110 group-hover:bg-blue-600/30"
      >
        {icon}
      </div>

      <!-- Title -->

      <h3
        class="font-['Space_Grotesk'] text-2xl font-bold transition-colors duration-300 group-hover:text-blue-400"
      >
        {title}
      </h3>

    </div>

    <!-- Skills -->

    <div class="grid gap-3">

      {
        skills.map((skill) => (

          <SkillItem skill={skill} />

        ))
      }

    </div>

  </div>

</div>