---
const { platform } = Astro.props;
---

<div
  class="group relative rounded-2xl transition-all duration-300"
>

  <!-- Glow -->

  <div
    class="absolute -inset-1 rounded-2xl bg-blue-500/20 opacity-0 blur-xl transition-all duration-500 group-hover:opacity-100"
  ></div>

  <!-- Card -->

  <div
    class="relative rounded-2xl border border-zinc-800 bg-zinc-900 transition-all duration-300 group-hover:-translate-y-2 group-hover:border-blue-500"
  >

    <div class="flex items-center gap-5 p-6">

      <div class="overflow-hidden rounded-xl bg-zinc-950 p-2">

        <img
          src={platform.logo}
          alt={platform.name}
          class="h-14 w-14 object-contain transition-transform duration-500 group-hover:scale-110"
        />

      </div>

      <div class="flex-1">

        <h3
          class="text-xl font-semibold transition-colors duration-300 group-hover:text-blue-400"
        >
          {platform.name}
        </h3>

        <p class="mt-1 text-zinc-400">
          {platform.username}
        </p>

      </div>

    </div>

    <div class="px-6">

      <p class="text-sm leading-7 text-zinc-400">
        {platform.description}
      </p>

    </div>

    <div class="p-6">

      <a
        href={platform.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-blue-600 px-5 py-3 font-medium transition-all duration-300 hover:scale-105 hover:bg-blue-500"
      >

        {platform.button}

        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 7l-10 10M8 7h9v9"
          />
        </svg>

      </a>

    </div>

  </div>

</div>