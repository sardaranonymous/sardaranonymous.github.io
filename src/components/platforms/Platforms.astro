---
import { platforms } from "../../data/platforms";
import PlatformCard from "./PlatformCard.astro";
---

<section
  id="platforms"
  class="py-24 border-t border-zinc-800 bg-zinc-950"
>

  <div class="max-w-7xl mx-auto px-6">

    <div class="text-center mb-14">

      <p class="uppercase tracking-[0.3em] text-blue-400 text-sm font-semibold">
        Bug Bounty Platforms
      </p>

      <h2 class="mt-4 text-4xl font-bold">
        {platforms.title}
      </h2>

      <p class="mt-6 text-zinc-400 max-w-3xl mx-auto">
        {platforms.description}
      </p>

    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

      {
        platforms.items.map((platform) => (
          <PlatformCard platform={platform} />
        ))
      }

    </div>

  </div>

</section>