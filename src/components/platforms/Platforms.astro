---
import { platforms } from "../../data/platforms";
import PlatformCard from "./PlatformCard.astro";
---

<section
  id="platforms"
  class="py-24 border-t border-zinc-800 bg-zinc-950"
>

  <div class="max-w-7xl mx-auto px-6">

    <!-- Heading -->

    <div
      class="mb-14 text-center"
      data-aos="fade-up"
    >

      <p
        class="uppercase tracking-[0.3em] text-blue-400 text-sm font-semibold"
      >
        Bug Bounty Platforms
      </p>

      <h2
        class="mt-4 text-4xl font-bold"
      >
        {platforms.title}
      </h2>

      <p
        class="mt-6 max-w-3xl mx-auto text-zinc-400 leading-8"
      >
        {platforms.description}
      </p>

    </div>

    <!-- Cards -->

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {
        platforms.items.map((platform, index) => (

          <div
            data-aos="zoom-in-up"
            data-aos-delay={index * 120}
          >

            <PlatformCard
              platform={platform}
            />

          </div>

        ))
      }

    </div>

  </div>

</section>