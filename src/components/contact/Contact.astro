---
import { contact } from "../../data/contact";
---

<section id="contact" class="py-24 border-t border-zinc-800 bg-zinc-950">
  <div class="max-w-5xl mx-auto px-6">

    <div class="text-center mb-14">
      <p class="uppercase tracking-[0.3em] text-blue-400 text-sm font-semibold">
        Contact
      </p>

      <h2 class="mt-4 text-4xl font-bold">
        {contact.title}
      </h2>

      <p class="mt-6 text-zinc-400 max-w-2xl mx-auto">
        {contact.description}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

      {
        contact.contacts.map((item) => (

          <a
            href={item.link}
            target="_blank"
            class="rounded-xl border border-zinc-800 bg-zinc-900 p-6 hover:border-blue-500 transition"
          >

            <h3 class="text-xl font-semibold">
              {item.title}
            </h3>

            <p class="mt-3 text-zinc-400 break-all">
              {item.value}
            </p>

          </a>

        ))
      }

    </div>

  </div>
</section>